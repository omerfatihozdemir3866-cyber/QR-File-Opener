<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="QR File Opener"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="32dp"
        android:text="QR Tara ve Dosya Ac"
        android:textSize="14sp"
        android:textColor="#666666" />

    <Button
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="QR TARA"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/scanResultText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:background="#F2F5FA"
        android:text="Henuz QR taranmadi."
        android:textSize="13sp"
        android:scrollbars="vertical"
        android:maxLines="10" />

    <Button
        android:id="@+id/btnPickPdf"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="PDF SEC VE AC"
        android:textSize="16sp" />

</LinearLayout>
